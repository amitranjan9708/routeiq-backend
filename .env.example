# ==========================================
# RouteIQ Backend Environment Variables
# ==========================================

# 1. Flights — Google Flights (recommended, free, airline names + INR prices)
# Setup: cd backend && npm run flights:setup
# Uses vendor/flights-mcp-server (fast-flights) — https://github.com/smamidipaka6/flights-mcp-server
# google | kiwi | skyscanner | both | all  (default: both = Google + Kiwi + Skyscanner)
FLIGHT_PROVIDER=both
# Skyscanner MCP — experimental: https://github.com/shadyvb/mcp-skyscanner
# Setup: cd backend && npm run skyscanner:setup
SKYSCANNER_MCP_VENDOR_DIR=vendor/mcp-skyscanner
# Python 3.10+ required (not macOS Xcode 3.9)
SKYSCANNER_PYTHON=/opt/homebrew/bin/python3.12
SKYSCANNER_CURRENCY=INR
SKYSCANNER_MARKET=IN
SKYSCANNER_LOCALE=en-IN
# Set to 1 to skip Skyscanner (e.g. if CAPTCHA blocked on your network)
# SKYSCANNER_PROXY=http://user:pass@host:port
# SKYSCANNER_DISABLED=1
GOOGLE_FLIGHTS_VENDOR_DIR=vendor/flights-mcp-server
# Force INR on cloud hosts (Render US IPs otherwise get USD from Google Flights)
GOOGLE_FLIGHTS_CURRENCY=INR
# Sort mode → MCP tool: cheapest=get_cheapest_flights, balanced=get_best_flights, fastest=get_general_flights_info
# Default uses routeiq_export.py (same logic, INR-safe). Set GOOGLE_FLIGHTS_USE_MCP=1 for stdio MCP.
# UV_BIN=/Users/you/.local/bin/uv

# Kiwi MCP fallback (calendar month prices still use Kiwi)
# https://mcp.kiwi.com
APIFY_TOKEN=your_free_token_here

# 2. Trains — local indian-railways-mcp (free, no API key)
# Setup: cd backend && npm run railways:setup
# https://github.com/rajprem4214/indian-railways-mcp
INDIAN_RAILWAYS_MCP_SERVER=vendor/indian-railways-mcp/build/index.js
# Log train MCP / erail responses (fares, raw MCP JSON preview) to server console
TRAIN_MCP_DEBUG=1

# 2. AI Explainability (Gemini)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 3. Google Maps (Distance Matrix)
# Get from: Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here